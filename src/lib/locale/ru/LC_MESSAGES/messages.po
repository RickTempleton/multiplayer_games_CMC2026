msgid "registration.hint"
msgstr "Нажмите Enter или кнопку ПРОДОЛЖИТЬ"

msgid "registration.continue"
msgstr "ПРОДОЛЖИТЬ"

msgid "registration.empty_name"
msgstr "Имя не может быть пустым."

msgid "registration.long_name"
msgstr "Имя слишком длинное (максимум 18 символов)."

